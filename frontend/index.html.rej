+<!-- Settings Modal -->
+<div id="settingsModal" class="hidden" style="position: fixed; inset: 0; z-index: 5000; display: flex; align-items: center; justify-content: center; background: rgba(0,0,0,.8); backdrop-filter: blur(8px);">
+    <div class="fade-in" style="background: var(--bg); border: 1px solid var(--border); border-radius: 16px; width: 100%; max-width: 400px; padding: 24px; box-shadow: 0 20px 40px rgba(0,0,0,0.5);">
+        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
+            <h2 style="font-family: var(--font-head); font-size: 20px; font-weight: 700; margin: 0; color: var(--text); display: flex; align-items: center; gap: 8px;">
+                <span class="material-symbols-outlined">settings</span> <span data-i18n="settings">Settings</span>
+            </h2>
+            <button onclick="window.closeSettingsModal()" style="background: transparent; border: none; color: var(--muted); cursor: pointer;"><span class="material-symbols-outlined">close</span></button>
+        </div>
+        
+        <div style="display: flex; flex-direction: column; gap: 16px;">
+            <div style="display: flex; justify-content: space-between; align-items: center;">
+                <label style="color: var(--text); font-weight: 500;" data-i18n="language">Language</label>
+                <select id="settingsLanguage" style="background: var(--card-inset); border: 1px solid var(--border); color: var(--text); padding: 8px 12px; border-radius: 8px; font-family: var(--font-sans); outline: none;">
