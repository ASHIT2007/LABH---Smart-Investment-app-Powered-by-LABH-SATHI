+          try {
+            const resCountries = await fetch(NE_COUNTRIES_GEOJSON, {
+              mode: "cors",
+            });
+            if (!resCountries.ok) {
+              throw new Error("HTTP " + resCountries.status);
+            }
+            const geoJSON = await resCountries.json();
+            const features = geoJSON.features || [];
