{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/server.js" },
    { "source": "/chart/(.*)", "destination": "/server.js" },
    { "source": "/threats/(.*)", "destination": "/server.js" },
    { "source": "/auth/(.*)", "destination": "/server.js" },
    { "source": "/(.*)", "destination": "/frontend/$1" }
  ]
}
