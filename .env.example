# Copy this file to ".env" and fill in values. Never commit ".env".

# -----------------------------------------------------------------------------
# AI (Labh Sathi, vibe-trade, roast, sentiment, Threat Globe headlines via Groq)
# Get a key: https://console.groq.com/
# Without it, /api/globe-threat-zones still returns live Yahoo quotes; headlines fall back to Yahoo RSS.
# -----------------------------------------------------------------------------
GROQ_API_KEY=

# -----------------------------------------------------------------------------
# Logo.dev — company logos in the markets list (optional; app has a dev fallback)
# https://www.logo.dev/
# -----------------------------------------------------------------------------
LOGO_DEV_TOKEN=

# -----------------------------------------------------------------------------
# Server port (optional; default 3000)
# -----------------------------------------------------------------------------
# PORT=3000
